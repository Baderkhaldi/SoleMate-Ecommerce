<% const title = product.labelP + ' - SoleMate'; %>
<%- include('partials/header') %>

<a href="/" class="text-decoration-none small">&larr; Back to catalog</a>

<div class="row mt-3">
  <div class="col-md-6">
    <img src="<%= product.photoPath %>" class="img-fluid rounded shadow-sm" alt="<%= product.labelP %>">
  </div>
  <div class="col-md-6">
    <h2><%= product.labelP %></h2>
    <p class="text-muted"><%= product.category %></p>
    <h4 class="text-success">$<%= Number(product.priceP).toFixed(2) %></h4>
    <p class="my-3"><%= product.desP %></p>
    <p class="small text-muted">
      <% if (product.QtyP > 0) { %>
        <span class="badge bg-success">In stock</span> &middot; <%= product.QtyP %> available
      <% } else { %>
        <span class="badge bg-secondary">Out of stock</span>
      <% } %>
    </p>

    <% if (user && product.QtyP > 0) { %>
      <form method="POST" action="/add-to-cart" class="d-flex align-items-center gap-2 mt-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="productId" value="<%= product.idP %>">
        <label for="qty" class="form-label mb-0">Qty</label>
        <input type="number" name="quantity" id="qty" min="1" max="10" value="1"
               class="form-control" style="width:90px">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-cart-plus"></i> Add to Cart
        </button>
      </form>
    <% } else if (!user) { %>
      <div class="alert alert-info mt-3">
        Please <a href="/login?next=/product?id=<%= product.idP %>">log in</a> to add this item to your cart.
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
